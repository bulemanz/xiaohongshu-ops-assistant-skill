ADB_BIN=adb
ADB_VENDOR_KEYS=$HOME/.android
XHS_DEVICE_PROFILE=redmi-k80
XHS_TEXT_MODE=adb-keyboard
XHS_TIMEZONE=Asia/Shanghai
XHS_POST_SLOTS=13:00,19:00
XHS_COMMENT_SWEEP_INTERVAL_HOURS=0.25
XHS_MAX_AUTO_REPLIES=3
XHS_GITHUB_WINDOW_DAYS=7
XHS_GITHUB_PER_PAGE=8
XHS_STUDY_KEYWORD=OpenClaw
XHS_STUDY_WINDOW_DAYS=3
XHS_STUDY_PAGES=3
XHS_STUDY_MAX_SAMPLES=12
GITHUB_TOKEN=
XHS_CONTENT_PROVIDER=gemini
XHS_GEMINI_API_KEYS=
XHS_GEMINI_TRANSPORT=auto
XHS_GEMINI_REMOTE_VIA_GCLOUD=0
XHS_REMOTE_OPENCLAW=0
XHS_GCLOUD_ZONE=asia-northeast1-b
XHS_GCLOUD_INSTANCE=your-instance
XHS_GCLOUD_PROJECT=your-project-id
XHS_REMOTE_TEXT_COMMAND_TEMPLATE=
XHS_REMOTE_IMAGE_COMMAND_TEMPLATE=
